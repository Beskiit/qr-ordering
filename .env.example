# Supabase — copy this file to .env.local and fill in from your
# Supabase dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (Project Settings → API → service_role).
# SERVER ONLY — never expose to the browser. Used to create staff accounts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of this app (used to build QR code links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
